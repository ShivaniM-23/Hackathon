# ── ShadowTrace AI — EC2 Deployment Environment Variables ─────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── REQUIRED: Set this to your EC2 public IP or domain ────────────────────────
# Example: http://3.110.45.123 or http://yourdomain.com
APP_URL=http://YOUR_EC2_PUBLIC_IP:3000
NEXT_PUBLIC_API_URL=http://YOUR_EC2_PUBLIC_IP:8000

# ── Google OAuth (update redirect URI in Google Console too!) ─────────────────
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── AI API Key (Groq) ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_groq_api_key_here
